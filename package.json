{
  "name": "market-news-signal-system",
  "private": true,
  "version": "0.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "npm run dev --workspace @market-news/api",
    "dev:web": "npm run dev --workspace @market-news/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace @market-news/api",
    "db:migrate": "npm run db:migrate --workspace @market-news/api",
    "db:seed": "npm run db:seed --workspace @market-news/api"
  }
}
